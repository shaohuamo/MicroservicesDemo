{
  "Logging": {
    "LogLevel": {
      "Default": "Debug",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "PostgresConnection": "Host=$POSTGRES_HOST; Port=$POSTGRES_PORT; Database=$POSTGRES_DATABASE; Username=$POSTGRES_USER; Password=$POSTGRES_PASSWORD"
  }
}

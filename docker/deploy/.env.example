# Image tag configuration for docker-compose deployment
# By default, all images use 'latest' if these variables are not set

# Products Microservice image tag
PRODUCTS_IMAGE_TAG=latest

# API Gateway image tag
APIGATEWAY_IMAGE_TAG=latest

# Test Microservice image tag
TESTMICROSERVICE_IMAGE_TAG=latest

# Admin Web (frontend) image tag
ADMINWEB_IMAGE_TAG=latest

# Example: Pin to a specific CI build
# Set all variables to the same sha tag to ensure all services are from the same build:
# PRODUCTS_IMAGE_TAG=sha-a1b2c3d4e5f6
# APIGATEWAY_IMAGE_TAG=sha-a1b2c3d4e5f6
# TESTMICROSERVICE_IMAGE_TAG=sha-a1b2c3d4e5f6
# ADMINWEB_IMAGE_TAG=sha-a1b2c3d4e5f6
#
# Then start with:
# docker compose -f docker-compose.yml --env-file .env up -d
